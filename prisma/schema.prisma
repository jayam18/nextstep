generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id             String   @id @default(cuid())
  ranking        Int?
  name           String
  aliases        String?  // comma-separated nicknames for search: "Caltech", "UIUC, U of I"
  location       String
  acceptanceRate Float
  tuition        Int
  students       Int
  imageUrl       String
  tags           String // Stored as a comma-separated string for simplicity in SQLite

  // Categorical Vibe Metrics
  locationVibe   String? // Urban, Suburban, College Town, Rural
  socialVibe     String? // Greek Life Heavy, Work Hard Play Hard, Chill & Alternative, Quiet
  athleticsVibe  String? // D1 Powerhouse, Intramural Focus, Non-Athletic/Artsy
  academicVibe   String? // Highly Competitive, Collaborative, Intellectual, Pre-Professional
  campusIdentity String? // Historic, Modern, Activist
  
  specialties    String? // Stored as comma-separated string: "Engineering,Business,Arts"
  
  careerPaths    CareerPath[]
  
  // Detailed Modal Metrics
  logoUrl         String?
  website         String?
  satMath         Int?
  satReading      Int?
  actComposite    Int?
  topMajors       String? // JSON string or comma-separated top 5
  specialPrograms String? // LLM generated
  clubs           String? // LLM generated
  avgGpa          Float?  // LLM generated estimate
  studentLifeSnippet String?
  athleticsSnippet   String?
  safetySnippet      String?

  // T1 Tuition fields
  tuitionInState     Int?   // published in-state tuition + fees
  tuitionOutOfState  Int?   // published out-of-state tuition + fees
  avgNetPrice        Int?   // average net price after aid
  tuitionSourceUrl   String?
  tuitionYear        String? // e.g. "2023-24"

  // D1 Scorecard fields
  ipedsUnitId        Int?
  completionRate     Float?   // graduation rate within 150% normal time (6 years)
  medianEarnings     Int?     // median earnings 10 years after entry
  
  // G1 Net price by income level (overall title IV recipients)
  netPrice0_30k      Int?     // net price for income $0-$30,000
  netPrice30_48k     Int?     // net price for income $30,001-$48,000
  netPrice48_75k     Int?     // net price for income $48,001-$75,000
  netPrice75_110k    Int?     // net price for income $75,001-$110,000
  netPrice110kPlus   Int?     // net price for income $110,001+

  // Data Provenance
  scorecardDataSource String?
  scorecardRetrievedAt DateTime?

  // T2 Reciprocity relation
  reciprocity        TuitionReciprocity[]

  // S1 Special programs & constituent colleges
  programs           CollegeProgram[]

  // M1 Majors with outcomes
  majors             CollegeMajor[]

  // G1 Grants & scholarships
  aid                CollegeAid[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CareerPath {
  id       String    @id @default(cuid())
  name     String    @unique
  colleges College[]
}

model CollegeProgram {
  id          String  @id @default(cuid())
  collegeId   String
  name        String  // "Grainger College of Engineering"
  type        String  // constituent-school | honors-college | co-op | research | accelerated | study-abroad | other
  prominence  Int     // 1 = flagship jewel, 2 = notable, 3 = solid
  description String  // 1-2 sentences on why it matters
  knownFor    String? // comma-separated: "CS, ECE, Aerospace"
  sourceUrl   String?
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model CollegeAid {
  id              String   @id @default(cuid())
  collegeId       String
  name            String   // "Pell Grant", "Illinois MAP Grant", "Illinois Commitment"
  kind            String   // need-based | merit | federal | state | institutional | departmental
  typicalAwardMin Int?
  typicalAwardMax Int?
  awardNote       String?  // "full tuition", "renewable 4 yrs if GPA ≥ 3.0"
  eligibility     String?  // one-liner: income threshold, GPA/test floor, major, residency
  howToApply      String?  // "automatic with application" | "separate app, due Dec 1" | "FAFSA"
  sourceUrl       String   // REQUIRED — no source, no row
  sourceName      String   // "Federal Student Aid", "Illinois Student Assistance Commission"
  retrievedAt     DateTime @default(now())
  college         College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model CollegeMajor {
  id                        String  @id @default(cuid())
  collegeId                 String
  cipCode                   String   // 4-digit CIP without dot, e.g. "1107"
  name                      String   // "Computer Science"
  credential                String   // "bachelors"
  degreesAwarded            Int?     // counts.ipeds_awards2
  degreeShare               Float?   // % of the college's bachelor's degrees
  medianEarnings1yr         Int?     // earnings.1_yr.overall_median_earnings
  medianEarnings4yr         Int?     // earnings.4_yr.overall_median_earnings
  medianEarnings4yrNational Int?     // earnings.4_yr.overall_median_earnings_national (same CIP+credential)
  nationalP25               Int?     // earnings.4_yr.overall_p25_earnings_national
  nationalP75               Int?     // earnings.4_yr.overall_p75_earnings_national
  medianDebt                Int?     // debt.staff_grad_plus.all.eval_inst.median
  medianMonthlyPayment      Int?     // debt.staff_grad_plus.all.eval_inst.median_payment
  sourceUrl                 String
  retrievedAt               DateTime @default(now())
  rankings                  MajorRanking[]
  college                   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model MajorRanking {
  id             String  @id @default(cuid())
  collegeMajorId String
  source         String   // "US News Undergrad CS" | "CSRankings" | "ABET accredited"
  year           String   // "2026"
  rank           Int?     // null for binary markers like accreditation
  scope          String?  // "national", "public universities", specialty name
  sourceUrl      String
  retrievedAt    DateTime @default(now())
  major          CollegeMajor @relation(fields: [collegeMajorId], references: [id], onDelete: Cascade)
}

model TuitionReciprocity {
  id            String   @id @default(cuid())
  collegeId     String
  program       String   // "MSEP" | "WUE" | "ACM" | "NEBHE" | "institutional" | "none"
  eligibleStates String  // comma-separated: "IL,MO,WI" (or "*" for any out-of-state)
  rateType      String   // "pct-of-instate" | "flat" | "instate-rate" | "none"
  rateValue     Int?     // 150 (for pct), or dollar amount (for flat)
  conditions    String?  // "majors not offered in home state", "min 3.0 GPA", "limited slots"
  sourceUrl     String   // REQUIRED
  retrievedAt   DateTime @default(now())
  college       College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

